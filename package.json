{
  "name": "skill-unit",
  "version": "0.0.1",
  "description": "Structured, reproducible unit testing for AI agent skills",
  "type": "module",
  "bin": {
    "skill-unit": "./dist/cli/index.js"
  },
  "files": [
    "dist/"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "su": "tsx src/cli/index.ts",
    "dev": "npm run su",
    "build": "tsc && cp src/config/default-config.yml dist/config/default-config.yml",
    "lint": "eslint src/",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:skills": "npm run su -- test --all"
  },
  "dependencies": {
    "@inkjs/ui": "^2.0.0",
    "citty": "^0.2.2",
    "ink": "^6.8.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "react": "^19.2.4",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
